{
  "manifest_version": 3,
  "name": "Productivity Dashboard",
  "version": "1.0",
  "description": "Personal Productivity Dashboard",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
